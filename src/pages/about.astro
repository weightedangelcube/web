---
import Layout from "../layouts/layout.astro";
import "../styles/about.scss";
---

<Layout title="About me">
    <div class="columns">
        <div class="column left">
            <p class="big">
                My name is Angel Wang. I'm a weird Chinese girl living in Alberta, Canada. I write code and music to stop myself from going insane.
            </p>
            <hr>
            <h2>This website</h2>
            <p>
                This website was handwritten in Astro and Sass. It's hosted on GitHub Pages—you can find the source <a href="https://github.com/weightedangelcube/web">here</a>.
                The title font is <a href="https://pangrampangram.com/products/neue-machina-collection">PP Neue Machina</a> by Pangram Pangram, and the body font is <a href="https://rsms.me/inter/">Inter</a> by Rasmus Andersson.
            </p>
        </div>
        <div class="column right">
            <a class="big" href="https://insidethecube.tumblr.com/">Tumblr @insidethecube</a>
            <a class="big" href="https://github.com/weightedangelcube">GitHub @weightedangelcube</a>
            <a class="big" href="https://www.youtube.com/@weightedangelcube">YouTube @weightedangelcube</a>
        </div>
    </div>
</Layout>